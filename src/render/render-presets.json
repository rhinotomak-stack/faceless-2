{
  "version": "0.1",
  "groups": [
    {
      "id": "generic",
      "name": "Generic (HD for web, mobile devices...)",
      "renderer": "avformat",
      "type": "av",
      "profiles": [
        {
          "name": "MP4 - H264/AAC",
          "extension": "mp4",
          "args": "f=mp4 movflags=+faststart vcodec=libx264 crf=%quality g=15 acodec=aac ab=%audiobitrate",
          "vQualities": "15,45",
          "defaultVQuality": "23",
          "vBitrates": "20000,1000",
          "defaultVBitrate": "6000",
          "aQualities": "",
          "defaultAQuality": "",
          "aBitrates": "384,64",
          "defaultABitrate": "192",
          "speeds": "preset=veryslow;preset=slower;preset=slow;preset=medium;preset=fast;preset=faster;preset=veryfast;preset=superfast;preset=ultrafast",
          "defaultSpeedIndex": 3
        },
        {
          "name": "WebM - VP9/Opus",
